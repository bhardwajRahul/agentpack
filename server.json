{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ihorponom/agentpack",
  "description": "Repo-native task continuity for AI coding agents: a reviewed task-state ledger served over MCP.",
  "repository": {
    "url": "https://github.com/ihorponom/agentpack",
    "source": "github"
  },
  "version": "1.1.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "agentpack-cli",
      "version": "1.1.1",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ]
}
